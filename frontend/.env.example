VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_DEFAULT_ZONE_ID=zone-palk-01

# Supabase (free tier)
# Create project: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
