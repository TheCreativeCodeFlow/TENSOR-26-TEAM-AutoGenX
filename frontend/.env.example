VITE_OPENWEATHER_API_KEY=
# IMD open advisory endpoints (public feeds): https://mausam.imd.gov.in/
VITE_IMD_BASE_URL=
# INCOIS ocean data/public services: https://incois.gov.in/
VITE_INCOIS_BASE_URL=
