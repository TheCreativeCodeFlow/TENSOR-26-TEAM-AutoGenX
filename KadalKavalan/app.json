{
  "expo": {
    "name": "Kadal Kavalan",
    "slug": "KadalKavalan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B4F6C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kadalkavalan.app"
    },
    "android": {
      "package": "com.kadalkavalan.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B4F6C"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "mlApiUrl": "https://tensor-26-team-autogenx-1.onrender.com",
      "eas": {
        "projectId": "501995e9-8fe7-4bab-bb35-f209fc729005"
      }
    },
    "owner": "toxic121123"
  }
}
