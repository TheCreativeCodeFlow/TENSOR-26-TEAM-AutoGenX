APP_NAME=fisherfolk-sea-safety-backend
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
BODY_LIMIT=1mb
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
APP_TIMEZONE=Asia/Kolkata

# Keep true only for local demo. Set false for production.
MOCK_OTP_EXPOSURE=false

# Supabase auth verification (required for real OTP + Bearer token verification)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_AUTH_TIMEOUT_MS=5000

# Backend JWT auth used after Twilio OTP verification
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Twilio Verify (direct OTP provider)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_CHANNEL=sms

# Keep true only for development fallback auth headers.
ALLOW_DEMO_AUTH_FALLBACK=false

# Force live external data usage only (no synthetic/mock advisories/weather feeds)
STRICT_LIVE_DATA=true

# Emergency reference contact
COAST_GUARD_NUMBER=1554

# Optional external provider configuration (all student/free compatible)
# OpenWeather Marine/Weather free tier key
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org

# IMD public feeds (typically no API key)
IMD_BASE_URL=https://mausam.imd.gov.in
IMD_CAP_RSS_URL=https://cap-sources.s3.amazonaws.com/in-imd-en/rss.xml

# INCOIS public ocean/incident data feeds (typically no API key)
INCOIS_BASE_URL=https://incois.gov.in
INCOIS_HIGH_WAVE_URL=https://incois.gov.in/site/services/hwa.jsp
INCOIS_STORM_SURGE_URL=https://incois.gov.in/site/services/StormSurge.jsp
